# Copia este archivo a `.env.local` y rellena los valores (Supabase → Settings → API).
# La URL debe ser la base del proyecto: https://YOUR_PROJECT_REF.supabase.co (sin /rest/v1/).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Con Supabase configurado y migraciones aplicadas, activa lectura desde la BD (repos que respeten env.useSupabaseData).
# Flujo MVP recomendado en local: VITE_USE_SUPABASE_DATA=true tras aplicar migraciones 001–005 y bucket 004.
VITE_USE_SUPABASE_DATA=
# VITE_USE_SUPABASE_DATA=true

# Mentor real: requiere VITE_USE_SUPABASE_DATA=true, función Netlify `mentor-chat` desplegada y variables de servidor (ver docs).
# VITE_USE_MENTOR_API=true

# Opcional: URL pública https de la app (sin barra final). Si está definida y es válida, el registro (signUp)
# usa esta base para emailRedirectTo (ej. correos de confirmación hacia producción aunque registres desde local).
# Debe coincidir con Redirect URLs en Supabase → Authentication → URL configuration.
# VITE_PUBLIC_APP_URL=https://tu-app.netlify.app

# Opcional: rol del usuario demo cuando NO usas auth real (mock).
# VITE_MOCK_USER_ROLE=student

# Opcional: URI Postgres (Settings → Database → Connection string → URI) para aplicar 004+006 en local: `npm run db:apply-004-006` y verificar con `npm run db:verify-004-006`. No uses la anon key.
# SUPABASE_DB_URL=

# --- Solo en Netlify (Site → Environment variables), nunca en Vite / frontend ---
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
