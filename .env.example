# Copia este archivo a `.env.local` y rellena los valores (Supabase → Settings → API).
# La URL debe ser la base del proyecto: https://YOUR_PROJECT_REF.supabase.co (sin /rest/v1/).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USE_SUPABASE_DATA=
# Con Supabase configurado y migraciones aplicadas, activa lectura desde la BD (repos que respeten env.useSupabaseData).
# VITE_USE_SUPABASE_DATA=true

# Opcional: URL pública https de la app (sin barra final). Si está definida y es https válida, el registro (signUp)
# usa esta base para emailRedirectTo (ej. correos de confirmación hacia producción aunque registres desde local).
# Debe coincidir con una entrada en Supabase → Authentication → URL configuration → Redirect URLs.
# VITE_PUBLIC_APP_URL=https://tu-app.netlify.app

# Opcional: rol del usuario demo cuando NO usas auth real (mock).
# VITE_MOCK_USER_ROLE=student
